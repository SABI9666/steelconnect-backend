# ─── Server ────────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/steelconnect

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Firebase Admin SDK credentials (JSON key file or env vars)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_DOMAIN=noreply@steelconnectapp.com

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,https://steelconnectapp.com

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── WhatsApp Business API (Meta) ─────────────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup
#
# WHATSAPP_PHONE_NUMBER_ID:
#   Found on the API Setup page under "From" phone number.
#   It's a numeric string like "123456789012345".
#
# WHATSAPP_ACCESS_TOKEN:
#   Temporary (24h): Copy from the API Setup page.
#   Permanent: Create a System User in Meta Business Suite → Generate token
#   with "whatsapp_business_messaging" permission.
#
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
