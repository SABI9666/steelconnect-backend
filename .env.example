# ===========================================
# SteelConnect Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# --- Database ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/steelconnect

# --- Authentication ---
JWT_SECRET=your-strong-random-secret-min-32-chars
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Admin Seed (used only for initial setup) ---
ADMIN_EMAIL=admin@steelconnect.com
ADMIN_PASSWORD=your-strong-admin-password
OPS_EMAIL=operations@steelconnect.com
OPS_PASSWORD=your-strong-ops-password

# --- System Admin (for permanent delete operations) ---
SYSTEM_ADMIN_PASSWORD=your-strong-system-admin-password

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# --- Admin Notifications ---
ADMIN_REPORT_EMAIL=admin@yourdomain.com
ADMIN_WHATSAPP_NUMBER=91XXXXXXXXXX
ADMIN_PHONE_NUMBER=XXXXXXXXXX
ADMIN_INVOICE_EMAIL=admin@yourdomain.com

# --- CORS ---
CORS_ORIGIN=https://yourdomain.com,https://admin.yourdomain.com
NODE_ENV=production

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM_DOMAIN=noreply@yourdomain.com

# --- WhatsApp Business API ---
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_BUSINESS_ID=your-business-id
WHATSAPP_SENDER_NUMBER=your-sender-number

# --- TURN/STUN (Voice Calls) ---
METERED_API_KEY=your-metered-api-key
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential
TURN_SERVER=global.relay.metered.ca

# --- Firebase Admin ---
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# --- Web Push (VAPID) ---
# Auto-generated on first run if not set
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
